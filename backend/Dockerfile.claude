# Dockerfile.claude
FROM node:20-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Setup Python environment for MCP Server
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install mcp requests bandit

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Create workspace
WORKDIR /workspace
RUN mkdir -p /root/.claude

# Register the AgentForge MCP Server as a Plugin/Skill for Claude Code
# This is how Claude Code "learns" to use our Kanban and Slack tools
RUN echo '{ \
  "mcpServers": { \
    "agentforge": { \
      "command": "python3", \
      "args": ["/app/mcp_server.py"] \
    } \
  } \
}' > /root/.claude/config.json

# Default environment variables
ENV ANTHROPIC_BASE_URL="http://vllm:8000"
ENV ANTHROPIC_AUTH_TOKEN="dummy"
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"
ENV ANTHROPIC_DEFAULT_SONNET_MODEL="qwen-2.5-coder-32b"

CMD ["tail", "-f", "/dev/null"]
