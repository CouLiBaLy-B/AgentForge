# Dockerfile.sandbox
# This image is used by the agents to execute code, run tests, and perform git operations.
FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.cargo/bin:${PATH}"

# Install common dev tools
RUN pip install pytest ruff bandit

# Create workspace directory
WORKDIR /workspace

# Keep the container running if needed, though agents usually run commands via 'docker exec' or similar
CMD ["/bin/bash"]
