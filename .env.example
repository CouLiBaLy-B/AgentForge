# --- AgentForge Configuration Template ---

# 🔑 Authentication & API Tokens
# Your GitHub Personal Access Token (PAT) with 'repo' permissions
GITHUB_TOKEN=your_github_token_here

# Slack Integration (Optional)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your_signing_secret

# 🤖 LLM Infrastructure Selection
# Choose 'vllm' for local inference or 'freellmapi' for cloud gateway
LLM_SOURCE=vllm

# vLLM Configuration (Default local server)
VLLM_BASE_URL=http://localhost:8000/v1

# FreeLLMAPI Configuration (Alternative source)
FREELLM_BASE_URL=http://localhost:3001/v1
FREELLM_API_KEY=your_freellm_key_here

# 🧠 Model Selection
# Format: 'openai:model-name' or 'anthropic:model-name'
MAIN_MODEL=openai:deepseek-v4
CODER_MODEL=openai:deepseek-v4
REVIEWER_MODEL=openai:deepseek-v4
TEMPERATURE=0.1

# 🏗️ Claude Code CLI Integration
CLAUDE_CODE_ENABLED=true
# Maps 'Sonnet' requests to your local model for vLLM compatibility
CLAUDE_CODE_MODEL_MAPPING=qwen-2.5-coder-32b

# 📊 Backend & Persistence
KANBAN_API_URL=http://localhost:3000
DATABASE_URL=postgresql://user:pass@localhost:5432/agentforge
REDIS_URL=redis://localhost:6379

# 📂 Paths (Internal container paths, change only if not using Docker)
WORKSPACE_DIR=./workspace
LOGS_DIR=./workspace/logs
MEMORY_DIR=./backend/memory
SKILLS_DIR=./skills
